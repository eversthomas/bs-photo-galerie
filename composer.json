{
    "name": "bs-photo-galerie/bs-photo-galerie",
    "description": "BS Photo Galerie – modulare PHP-Fotogalerie",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "nikic/fast-route": "^1.3",
        "vlucas/phpdotenv": "^5.6",
        "intervention/image": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "BSPhotoGalerie\\": "app/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "suggest": {
        "ext-exif": "EXIF-Metadaten beim Upload auslesen",
        "ext-fileinfo": "MIME-Typen per finfo prüfen",
        "ext-gd": "Bildverarbeitung und Vorschaubilder (Intervention Image)",
        "ext-ftp": "FTP-Holen in den Import-Ordner (optional)"
    }
}

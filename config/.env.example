# Kopieren nach .env und anpassen (optional – Installer legt DB in config/config.php an)
APP_ENV=development
INSTALL_DEV_RESET=true

# Bei HTTP 500: Exception-Details im Browser (nur in vertrauenswürdiger Umgebung; Production: aus oder 0)
# APP_DEBUG=0

# Content-Security-Policy nur im Report-Only-Modus (blockiert nichts; optional zum Testen)
# BSPHOTO_CSP_REPORT_ONLY=1

# Admin-Sitzung: automatische Abmeldung bei Inaktivität (Sekunden, 0 = wie bisher unbegrenzt bis Browser/Session endet)
# BSPHOTO_SESSION_IDLE_SECONDS=3600

# Cross-Origin-Opener-Policy: same-origin (Standard an; nur bei Problemen mit Popups/Embeds abschalten)
# BSPHOTO_COOP_SAME_ORIGIN=0

# Optional: GitHub API (höheres Rate-Limit für den Update-Check im Backend)
# GITHUB_API_TOKEN=
#
# Deployment: DocumentRoot muss auf public/ zeigen — config/ liegt außerhalb und ist nicht web-erreichbar.
# Zusätzlich schützt config/.htaccess unter Apache. .env niemals ins Repository committen.

# Web-Update aus der Verwaltung (ZIP von GitHub ohne .git, oder Git wenn .git vorhanden):
# BSPHOTO_ALLOW_WEB_UPDATE=0
# (ältere Variable, gilt weiterhin wie BSPHOTO_ALLOW_WEB_UPDATE)
# BSPHOTO_ALLOW_GIT_UPDATE=0

# Öffentliche Basis-URL der Galerie (optional, für absolute Links — wird in den Einstellungen gepflegt):
# public_base_url wird in der DB/Settings gespeichert, nicht hier zwingend.
